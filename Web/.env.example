# EtsyOS Web — required environment variables
# The console reads AND writes product fiches through the GitHub Contents API.
# It never touches the local filesystem (there is none in the Cloudflare Pages
# Workers runtime at request time) and never calls Etsy/Printify/image-gen.

# Fine-grained GitHub PAT with "Contents: Read and write" on the EtsyOS repo.
# Not created yet — generate at github.com/settings/tokens and set as a
# Cloudflare Pages secret (and a Pages *Preview* secret) after deploy.
GITHUB_TOKEN=

# owner/repo that stores the product fiches.
GITHUB_REPO=MySpaceBoats/EtsyOS

# branch to read/write.
GITHUB_BRANCH=main

# Local dev / CI verification ONLY. Set to 1 to bypass GitHub entirely and serve
# the bundled seed listings from lib/mock.ts. NEVER set this in production.
MOCK_DATA=0
