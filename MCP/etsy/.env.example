# Etsy app credentials — from https://www.etsy.com/developers/your-apps
ETSY_CLIENT_ID=
# Registered redirect URI for the "authorize" one-time script (localhost is allowed by Etsy for dev apps)
ETSY_REDIRECT_URI=http://localhost:3945/callback
# Space-separated scopes — read-only for Phase 1
ETSY_SCOPES=shops_r listings_r transactions_r
# Filled in automatically by `npm run authorize` — do not edit by hand
ETSY_TOKEN_CACHE_PATH=.etsy-tokens.json
# Numeric shop ID — printed by `npm run authorize`, or looked up via GET /v3/application/users/{user_id}/shops
ETSY_SHOP_ID=
