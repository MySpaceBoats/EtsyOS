# Cloudflare R2 — https://dash.cloudflare.com > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional — defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Optional — public bucket base (custom domain or pub-<hash>.r2.dev), enables publicUrl()
R2_PUBLIC_URL_BASE=
